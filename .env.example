# Typex Environment Variables
# Copy this file to .env and fill in your actual values

# EmailJS Configuration (for Contact Form)
# Get these from https://dashboard.emailjs.com/admin/account
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Google Analytics 4 Measurement ID
# Get this from https://analytics.google.com/analytics/web/
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense Publisher ID (after approval)
# Format: ca-pub-XXXXXXXXXXXXXXXX
# VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Site URL (for SEO)
VITE_SITE_URL=https://typex.arkio.in
